# Thin loader — all real config lives in ~/.config/git/config
[include]
    path = ~/.config/git/config

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[core]
	sshCommand = ssh -i ~/.ssh/id_ed25519_sk -o IdentitiesOnly=yes

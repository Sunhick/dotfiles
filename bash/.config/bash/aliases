#!/usr/bin/env bash

# Navigation shortcuts
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias ~="cd ~"
alias -- -="cd -"

# List directory contents (generic fallback; darwin overrides for macOS)
alias ls="ls --color=auto"
alias l="ls -lah"
alias la="ls -lAh"
alias ll="ls -lh"
alias lsa="ls -lah"

# Colorize output
alias grep='grep --color=auto'
alias fgrep='grep -F --color=auto'
alias egrep='grep -E --color=auto'
alias tree='tree -C'

# Git shortcuts
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git pull"
alias gd="git diff"
alias gb="git branch"
alias gco="git checkout"

# Safety aliases
alias rm="rm -i"
alias cp="cp -i"
alias mv="mv -i"

# Utility shortcuts
alias h="history"
alias j="jobs"
alias c="clear"
alias reload='source "${XDG_CONFIG_HOME:-$HOME/.config}/bash/bashrc"'

# Modern tool replacements (separate names to avoid flag confusion)
command -v bat >/dev/null && alias cat="bat"
command -v fd >/dev/null && alias fdfind="fd"
command -v rg >/dev/null && alias search="rg"

# eza/exa override for ls (last wins, intentional)
if command -v eza >/dev/null 2>&1; then
    alias ls="eza --color=auto"
    alias l="eza -lah"
    alias la="eza -lAh"
    alias ll="eza -lh"
    alias lsa="eza -lah"
elif command -v exa >/dev/null 2>&1; then
    alias ls="exa --color=auto"
    alias l="exa -lah"
    alias la="exa -lAh"
    alias ll="exa -lh"
    alias lsa="exa -lah"
fi

# Emacs shortcuts
alias kill-emacs='emacsclient -e "(kill-emacs)"'
alias e="emacsclient -n"
alias ec="emacsclient -c"

#!/usr/bin/env bash

# XDG Base Directory Specification
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

# Bash configuration directory
BASH_CONFIG_DIR="${XDG_CONFIG_HOME}/bash"

# Safe source function
include() {
    if [[ -f "$1" ]]; then
        source "$1"
    elif [[ "${2:-}" != "optional" ]]; then
        echo "Warning: Could not source $1" >&2
    fi
}

# Detect Docker environment
if [[ -f "/.dockerenv" ]]; then
    # Inside Docker – use container-specific rc
    include "${XDG_CONFIG_HOME}/bash/dockerrc" "optional"
    return
fi

# Load shell options first
include "${BASH_CONFIG_DIR}/shopt"

# Load readline configuration (XDG compliant)
# Skip inside Emacs where line editing is unavailable
if [[ -z "$INSIDE_EMACS" && "$TERM" != "dumb" ]]; then
    if [[ -f "${XDG_CONFIG_HOME}/readline/inputrc" ]]; then
        bind -f "${XDG_CONFIG_HOME}/readline/inputrc"
    fi
fi

# Load environment variables
include "${BASH_CONFIG_DIR}/exports"

# Load history configuration
include "${BASH_CONFIG_DIR}/history" "optional"

# Load colors and prompt
include "${BASH_CONFIG_DIR}/colors"
include "${BASH_CONFIG_DIR}/prompt"

# Load aliases
include "${BASH_CONFIG_DIR}/aliases"

# Load OS-specific configuration
case "$(uname -s)" in
    Darwin)
        include "${BASH_CONFIG_DIR}/darwin"
        ;;
    Linux)
        include "${BASH_CONFIG_DIR}/linux"
        ;;
esac

# Load git completion only (skip bash-completion — _longopt breaks macOS)
if [[ -z "$INSIDE_EMACS" && "$TERM" != "dumb" ]]; then
    for _git_comp in \
        "/opt/homebrew/opt/git/etc/bash_completion.d/git-completion.bash" \
        "/opt/homebrew/etc/bash_completion.d/git-completion.bash" \
        "/usr/share/bash-completion/completions/git"; do
        if [[ -r "$_git_comp" ]]; then
            source "$_git_comp"
            break
        fi
    done
    unset _git_comp
fi

# Load fzf keybindings only (Ctrl-R, Ctrl-T, Alt-C)
if [[ -z "$INSIDE_EMACS" ]]; then
    include "${XDG_CONFIG_HOME}/fzf/fzf.bash" "optional"
fi

# Load dir_colors for ls coloring (cached to avoid subprocess on every shell)
_dircolors_cache="${XDG_CACHE_HOME:-$HOME/.cache}/bash/dir_colors.sh"
if [[ ! -f "$_dircolors_cache" || "${BASH_CONFIG_DIR}/dir_colors" -nt "$_dircolors_cache" ]]; then
    mkdir -p "$(dirname "$_dircolors_cache")"
    if command -v gdircolors >/dev/null 2>&1; then
        if [[ -f "${BASH_CONFIG_DIR}/dir_colors" ]]; then
            gdircolors -b "${BASH_CONFIG_DIR}/dir_colors" > "$_dircolors_cache"
        else
            gdircolors -b > "$_dircolors_cache"
        fi
    elif command -v dircolors >/dev/null 2>&1; then
        if [[ -f "${BASH_CONFIG_DIR}/dir_colors" ]]; then
            dircolors -b "${BASH_CONFIG_DIR}/dir_colors" > "$_dircolors_cache"
        else
            dircolors -b > "$_dircolors_cache"
        fi
    fi
fi
[[ -f "$_dircolors_cache" ]] && source "$_dircolors_cache"
unset _dircolors_cache

# Load local machine-specific overrides
include "${XDG_CONFIG_HOME}/work/bash/local" "optional"

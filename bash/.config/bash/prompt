#!/usr/bin/env bash

# Arrow glyph
glyph_arrow='❯'

# Git branch function
git_branch() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [[ -n "$branch" ]]; then
        echo " ${bold_blue}(${branch})${reset_color}"
    fi
}

# Prompt command function
prompt_command() {
    local last_exit_code=$?

    # Flush history so other terminals can see it
    history -a

    local prompt=""

    # Show AWS profile if set
    if [[ -n "$AWS_PROFILE" ]]; then
        prompt+="${bold_orange}[${AWS_PROFILE}]${reset_color} "
    fi

    # Status indicator based on last exit code
    if [[ "$last_exit_code" -ne 0 ]]; then
        prompt+="${bold_red}${glyph_arrow}${reset_color} "
    else
        prompt+="${bold_green}${glyph_arrow}${reset_color} "
    fi

    # Current working directory
    prompt+="${bold_cyan}\W${reset_color}"

    # Git branch if in a git repository
    # prompt+="$(git_branch)"

    # Final prompt character
    prompt+=" ${bold_white}❯${reset_color} "

    # Set terminal title: user:dirname
    prompt="\[\e]0;\u:\W\a\]${prompt}"

    PS1="$prompt"
    PS2="${bold_yellow}>${reset_color} "
}

# Set up prompt based on terminal capability
if [[ -n "$INSIDE_EMACS" ]]; then
    # Inside Emacs shell-mode — plain prompt, no ANSI escapes
    # Comint with TERM=dumb doesn't render colors reliably
    _emacs_prompt_command() {
        local last_exit=$?
        local indicator branch=""
        if [[ "$last_exit" -ne 0 ]]; then
            indicator="✗"
        else
            indicator="❯"
        fi
        branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
        if [[ -n "$branch" ]]; then
            branch=" ($branch)"
        fi
        PS1="${indicator} \W${branch} ❯ "
    }
    PROMPT_COMMAND="_emacs_prompt_command"
elif [[ "$TERM" == "dumb" || "$TERM" == "unknown" ]]; then
    PS1="> "
else
    PROMPT_COMMAND="prompt_command"
fi
